{
  "info": {
    "name": "SaaS Integration Hub",
    "description": "API collection for the SaaS Integration Hub — Stripe webhooks, Resend email, Slack alerts, and event log.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "adminApiKey", "value": "replace-with-your-admin-api-key", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health",
        "description": "Check server health."
      }
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "List Events",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/events?limit=20&page=1",
              "host": ["{{baseUrl}}"],
              "path": ["events"],
              "query": [
                { "key": "limit", "value": "20" },
                { "key": "page", "value": "1" },
                { "key": "type", "value": "", "disabled": true },
                { "key": "status", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Event by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/events/:id"
          }
        },
        {
          "name": "Simulate Event",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/events/simulate",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{adminApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"payment_intent.succeeded\",\n  \"amount\": 4999,\n  \"currency\": \"usd\",\n  \"customerEmail\": \"demo@example.com\"\n}"
            }
          }
        },
        {
          "name": "Simulate Inventory Alert",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/inventory/simulate",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{adminApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productTitle\": \"Demo Hoodie\",\n  \"sku\": \"DEMO-HOODIE\",\n  \"inventoryQuantity\": 3\n}"
            }
          }
        },
        {
          "name": "Simulate Delivery Update",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/delivery/simulate",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{adminApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trackingNumber\": \"MOCK123456789\",\n  \"carrier\": \"Mock Carrier\",\n  \"deliveryStatus\": \"transit\",\n  \"customerEmail\": \"demo@example.com\"\n}"
            }
          }
        },
        {
          "name": "Delete Event",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/events/:id",
            "header": [{ "key": "x-api-key", "value": "{{adminApiKey}}" }]
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Send Email",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/notify/email",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{adminApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"to\": \"demo@example.com\",\n  \"subject\": \"Test email from SaaS Integration Hub\",\n  \"html\": \"<strong>Your payment was received.</strong>\"\n}"
            }
          }
        },
        {
          "name": "Send Slack Alert",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/notify/slack",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{adminApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"payment_intent.succeeded\",\n  \"amount\": 4999,\n  \"currency\": \"usd\",\n  \"customerEmail\": \"demo@example.com\",\n  \"status\": \"processed\"\n}"
            }
          }
        }
      ]
    }
  ]
}
